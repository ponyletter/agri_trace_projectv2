/* pages/index/index.wxss */
.container { background: #f5f5f5; min-height: 100vh; }

.banner { position: relative; height: 200rpx; overflow: hidden; }
.banner-img { width: 100%; height: 100%; }
.banner-text {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: rgba(26, 82, 118, 0.7);
}
.banner-title { color: #fff; font-size: 40rpx; font-weight: 700; }
.banner-sub { color: rgba(255,255,255,0.8); font-size: 24rpx; margin-top: 8rpx; }

.section { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }

.scan-area { display: flex; justify-content: center; }
.btn-scan {
  display: flex; flex-direction: column; align-items: center;
  background: linear-gradient(135deg, #1a5276, #27ae60);
  color: #fff; border-radius: 16rpx; padding: 30rpx 60rpx;
  border: none;
}
.scan-icon { width: 80rpx; height: 80rpx; margin-bottom: 12rpx; }

.input-area { display: flex; gap: 16rpx; }
.trace-input {
  flex: 1; border: 2rpx solid #ddd; border-radius: 8rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; background: #f9f9f9;
}
.btn-query {
  background: #1a5276; color: #fff; border-radius: 8rpx;
  padding: 0 32rpx; font-size: 28rpx; border: none;
}

.example-list { display: flex; flex-direction: column; gap: 16rpx; }
.example-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx; background: #f0f8ff; border-radius: 8rpx;
  border-left: 6rpx solid #27ae60;
}
.example-name { font-size: 28rpx; color: #333; }
.example-code { font-size: 22rpx; color: #888; }
