/* pages/result/result.wxss */
.container { background: #f5f5f5; min-height: 100vh; padding: 20rpx; }

.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; }

.status-tag { padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; color: #fff; }
.status-0 { background: #909399; }
.status-1 { background: #e6a23c; }
.status-2 { background: #409eff; }
.status-3 { background: #e6a23c; }
.status-4 { background: #67c23a; }

.info-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.info-item { width: calc(50% - 8rpx); }
.info-item.full-width { width: 100%; }
.info-label { font-size: 24rpx; color: #888; display: block; margin-bottom: 4rpx; }
.info-value { font-size: 28rpx; color: #333; }
.batch-no { font-size: 22rpx; color: #1a5276; word-break: break-all; }

/* 时间轴 */
.timeline { padding-left: 20rpx; }
.timeline-item { display: flex; position: relative; padding-bottom: 32rpx; }
.timeline-dot {
  width: 24rpx; height: 24rpx; border-radius: 50%; flex-shrink: 0;
  margin-top: 8rpx; margin-right: 20rpx; z-index: 1;
}
.dot-planting { background: #67c23a; }
.dot-harvesting { background: #e6a23c; }
.dot-inspecting { background: #409eff; }
.dot-packing { background: #909399; }
.dot-transporting { background: #17a2b8; }
.dot-retailing { background: #f56c6c; }

.timeline-line {
  position: absolute; left: 11rpx; top: 32rpx; bottom: 0;
  width: 2rpx; background: #e8e8e8;
}
.timeline-content { flex: 1; }
.node-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.node-tag { padding: 4rpx 12rpx; border-radius: 4rpx; font-size: 22rpx; color: #fff; }
.tag-planting { background: #67c23a; }
.tag-harvesting { background: #e6a23c; }
.tag-inspecting { background: #409eff; }
.tag-packing { background: #909399; }
.tag-transporting { background: #17a2b8; }
.tag-retailing { background: #f56c6c; }
.node-time { font-size: 22rpx; color: #888; }
.node-location { font-size: 26rpx; color: #555; display: block; margin-bottom: 8rpx; }

.env-data { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 8rpx; }
.env-item {
  background: #e8f5e9; border-radius: 4rpx; padding: 4rpx 10rpx;
  display: flex; gap: 4rpx;
}
.env-key { font-size: 22rpx; color: #666; }
.env-val { font-size: 22rpx; color: #2e7d32; }

.chain-info { display: flex; gap: 20rpx; }
.chain-hash, .block-height { font-size: 20rpx; color: #aaa; }

.verify-card { background: #f0fff4; border: 1rpx solid #b7eb8f; }
.verify-text { font-size: 26rpx; color: #389e0d; line-height: 1.6; }

.empty { display: flex; justify-content: center; align-items: center; height: 400rpx; color: #888; }
